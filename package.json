{
  "name": "suko-o-shot",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "sync": "npm run build && cap sync",
    "ios": "npm run build && cap sync ios && cap open ios",
    "android": "export JAVA_HOME=\"/Applications/Android Studio.app/Contents/jbr/Contents/Home\" && npm run build && cap sync android && cap open android",
    "dev:ios": "CAPACITOR_DEV=true cap sync ios && vite",
    "dev:android": "export JAVA_HOME=\"/Applications/Android Studio.app/Contents/jbr/Contents/Home\" && CAPACITOR_DEV=true cap sync android && vite"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.5"
  }
}
